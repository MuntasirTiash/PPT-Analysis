# ============================================================
# Environment & secrets — NEVER commit these
# ============================================================
.env
*.pem
*.key

# ============================================================
# Data files — too large or potentially proprietary
# ============================================================
data/
*.csv
*.xlsx
*.xls
*.zip
*.rar
*.tar.gz
*.pdf
*.mp3
*.wav

# Analysis result files (large generated outputs)
*.json
# Keep .env.example (override the *.json rule above)
!.env.example

# Fine-tuning datasets (generated by prepare_finetune_dataset.py)
finetune_data/
finetuned_csr_model/

# ============================================================
# Python artifacts
# ============================================================
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/
*.egg

# Virtual environments
.venv/
venv/
env/
.mm/
.multi_modal/

# ============================================================
# Jupyter
# ============================================================
.ipynb_checkpoints/
*.ipynb_checkpoints

# ============================================================
# IDE / OS
# ============================================================
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo
