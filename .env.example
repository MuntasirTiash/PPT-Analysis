# ============================================================
# API Keys — copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.
# ============================================================

# Google Gemini API Key (required for analyze_gemini.py)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (required for analyze_openai.py and --backend openai in finetune_vlm.py)
OPENAI_API_KEY=your_openai_api_key_here

# HuggingFace token (required for --backend huggingface in finetune_vlm.py)
# Get yours at: https://huggingface.co/settings/tokens
HF_AUTH_TOKEN=your_huggingface_token_here

# ============================================================
# Data Paths — set these to your local data directories.
# ============================================================

# Root directory containing per-year PDF folders (e.g. ppt_2018/)
PDF_BASE_DIR=/path/to/your/ppt_data

# Root directory for analysis output files
RESULTS_BASE_DIR=/path/to/your/results

# Directory containing per-year Excel index files (data(mp3+ppt)_YYYY.xlsx)
INDEX_BASE_DIR=/path/to/your/index_files

# Path to the Cumulative Abnormal Returns CSV
CAR_PATH=/path/to/your/CAR/3factor_post4_13.csv
